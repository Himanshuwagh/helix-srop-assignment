# ── LLM Provider ────────────────────────────────────────────────────────────
# Pick one. ADK uses GOOGLE_API_KEY by default; for others, wire in litellm.
GOOGLE_API_KEY=your-google-api-key-here
# OPENAI_API_KEY=your-openai-api-key-here
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (default for local dev)
DATABASE_URL=sqlite+aiosqlite:///./helix_srop.db
# Postgres (for Postgres-compatible schema):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/helix_srop

# ── Vector Store ──────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
# LANCEDB_PATH=./lancedb
# PINECONE_API_KEY=...
# PINECONE_INDEX=helix-docs

# ── App Settings ──────────────────────────────────────────────────────────────
APP_ENV=development              # development | production
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
SECRET_KEY=change-me-in-prod     # used for JWT signing (extension E2)

# ── Model Selection ───────────────────────────────────────────────────────────
# ADK Gemini model id (Google AI Studio free tier; limits vary by model).
# Prefer 2.5 flash-lite : cheaper / higher TPM than full flash on many free quotas.
ADK_MODEL=gemini-2.5-flash-lite  # or: gemini-2.5-flash, gemini-2.5-pro (stricter quotas)

# ── Agent Timeouts ────────────────────────────────────────────────────────────
LLM_TIMEOUT_SECONDS=30
TOOL_TIMEOUT_SECONDS=10
